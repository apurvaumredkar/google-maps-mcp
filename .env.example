# Required
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: set when exposing the server over a network or proxy (e.g. nginx, ngrok).
# Clients must then send this value in the X-Api-Key header.
# Omit or leave blank for local-only use (no authentication).
# Generate with: openssl rand -hex 32
# MCP_AUTH_TOKEN=your_secret_token_here

# Optional: required only for the routes_optimize tool (Route Optimization API)
# GOOGLE_CLOUD_PROJECT_ID=your_project_id

# Optional: change the default port (3003)
# PORT=3003
